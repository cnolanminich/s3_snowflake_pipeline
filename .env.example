# S3 Source
S3_BUCKET_URL=s3://your-data-bucket/path
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Snowflake
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=public
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_ROLE=your_role

# dbt Cloud
DBT_CLOUD_ACCOUNT_ID=12345
DBT_CLOUD_API_TOKEN=your_dbt_cloud_token
DBT_CLOUD_PROJECT_ID=67890
DBT_CLOUD_ENVIRONMENT_ID=1
DBT_CLOUD_ACCESS_URL=https://cloud.getdbt.com

# Hightouch
HIGHTOUCH_SYNC_ID=your_sync_id
HIGHTOUCH_API_KEY=your_hightouch_api_key
